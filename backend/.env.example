# Copy to .env and edit. All values have safe dev defaults.

# Database — SQLite for dev; Postgres for production:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/tunneldt
DATABASE_URL=sqlite:///./tunnel_dt.db

# Auth — dev mode mints/verifies local HS256 tokens (no IdP needed).
# For production set AUTH_DEV_MODE=false and configure OIDC:
AUTH_DEV_MODE=true
JWT_SECRET=dev-only-change-me-to-a-real-32byte+-secret
# OIDC_ISSUER=https://your-tenant.auth0.com
# OIDC_AUDIENCE=https://api.tunnel-dt.example

# Path to the Streamlit repo with utils/ (defaults to the parent dir).
# REPO_ROOT=/abs/path/to/Tunnel-DT2026

CORS_ORIGINS=http://localhost:8501
