# Logs
*.log
logs/

# Large reference library — standards & datasets (~5 GB), not code.
# The app links to it via utils/library.py at runtime; it is not versioned.
# Exception: the manuscript LaTeX source is tracked; the bulky data is not.
2026 Ontology Paper/*
!2026 Ontology Paper/_Submission.tex
!2026 Ontology Paper/_Revision 1.tex

# Runtime-generated user data (tunnels created on the Tunnel Setup page)
data/custom_tunnels.json

# Local scratch launcher note
Tunnel-DT2026_streamlit.py
